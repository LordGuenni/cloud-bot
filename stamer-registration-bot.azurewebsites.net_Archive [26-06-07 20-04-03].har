          "content": {
            "mimeType": "text/css; charset=utf-8",
            "size": 1036,
            "text": "body {\n  margin: 0;\n  font-family: Arial, sans-serif;\n  background: #0f172a;\n  color: #e2e8f0;\n}\n\n.container {\n  max-width: 880px;\n  margin: 0 auto;\n  padding: 24px;\n}\n\nh1 {\n  margin-top: 0;\n  font-size: 1.4rem;\n}\n\n.chat {\n  min-height: 420px;\n  max-height: 65vh;\n  overflow-y: auto;\n  border: 1px solid #334155;\n  border-radius: 10px;\n  padding: 12px;\n  background: #111827;\n}\n\n.msg {\n  margin: 8px 0;\n  padding: 10px 12px;\n  border-radius: 8px;\n  max-width: 90%;\n  white-space: pre-wrap;\n}\n\n.bot {\n  background: #1e293b;\n}\n\n.user {\n  background: #164e63;\n  margin-left: auto;\n}\n\n.composer {\n  display: flex;\n  gap: 8px;\n  margin-top: 12px;\n}\n\n.composer input {\n  flex: 1;\n  border-radius: 8px;\n  border: 1px solid #334155;\n  background: #020617;\n  color: #e2e8f0;\n  padding: 10px;\n}\n\n.composer button {\n  border: 1px solid #334155;\n  background: #0b5ed7;\n  color: white;\n  border-radius: 8px;\n  padding: 8px 12px;\n  cursor: pointer;\n}\n\n.composer #voice-btn {\n  background: #7c3aed;\n}\n\n.hint {\n  color: #94a3b8;\n  font-size: 0.9rem;\n}\n"
          },
