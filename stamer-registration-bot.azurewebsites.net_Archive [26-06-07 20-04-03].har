          "content": {
            "mimeType": "text/html; charset=utf-8",
            "size": 964,
            "text": "<!doctype html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"utf-8\" />\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n    <title>Registration Bot Prototype</title>\n    <link rel=\"stylesheet\" href=\"/static/style.css\" />\n  </head>\n  <body>\n    <main class=\"container\">\n      <h1>Registration Bot (Browser Chat + Voice)</h1>\n      <div id=\"chat\" class=\"chat\"></div>\n      <form id=\"chat-form\" class=\"composer\">\n        <input id=\"message\" type=\"text\" autocomplete=\"off\" placeholder=\"Type your message...\" />\n        <button type=\"submit\">Send</button>\n        <button id=\"voice-btn\" type=\"button\">🎤 Voice</button>\n      </form>\n      <p class=\"hint\">\n        Voice input/output uses Azure Speech Services. Commands: <code>restart</code>,\n        <code>yes</code>/<code>no</code>.\n      </p>\n    </main>\n    <script src=\"https://aka.ms/csspeech/jsbrowserpackageraw\"></script>\n    <script src=\"/static/app.js\"></script>\n  </body>\n</html>\n"
          },
